{
  "id": "multi-agent-orchestrator",
  "version": "2.0.0",
  "author": "haiyuzhong1980",
  "name": "OpenClaw Multi-Agent Orchestrator",
  "description": "Deterministic multi-agent task orchestration with agent registry, OFMS integration, track templates, and self-evolving intent detection.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabledPromptGuidance": {
        "type": "boolean"
      },
      "maxItemsPerTrack": {
        "type": "integer",
        "minimum": 1,
        "maximum": 20
      },
      "executionPolicy": {
        "type": "string",
        "enum": [
          "free",
          "guided",
          "tracked",
          "delegation-first",
          "strict-orchestrated"
        ]
      },
      "delegationStartGate": {
        "type": "string",
        "enum": [
          "off",
          "advisory",
          "required"
        ]
      }
    }
  },
  "uiHints": {
    "enabledPromptGuidance": {
      "label": "Enable Prompt Guidance"
    },
    "maxItemsPerTrack": {
      "label": "Max Items Per Track"
    },
    "executionPolicy": {
      "label": "Execution Policy"
    },
    "delegationStartGate": {
      "label": "Delegation Start Gate"
    }
  }
}
